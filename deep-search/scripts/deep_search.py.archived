#!/usr/bin/env python3
"""
deep-search v3.2 — 关键词→英文翻译→搜索计划→SearXNG+Firecrawl(双引擎6轮)→合并去重→scrapling(优先)/Firecrawl(兜底)抓取→报告
v3.2: 双引擎并行搜索 + 分级抓取（scrapling→Firecrawl）
架构：计划驱动，SearXNG与Firecrawl互补，抓取自俭。
"""

import json, os, sys, time, subprocess, re
from datetime import datetime, timezone, timedelta
from pathlib import Path
from concurrent.futures import ThreadPoolExecutor, as_completed, TimeoutError as FuturesTimeout
from urllib.parse import urlparse

# ── 配置 ──────────────────────────────
MAX_ROUNDS = 6
MAX_RESULTS_PER_ROUND = 8
SCRAPING_WORKERS = 3
FETCH_TIMEOUT = 20
DDGS_TIMEOUT = 15
MAX_SCRAPE = 15              # 单次搜索最多抓取条数
SEARXNG_URL = "http://127.0.0.1:8880"
SEARXNG_ENGINES = "baidu,bing,360search,sogou"
OUTPUT_ROOT = Path("/tmp/deep_search")

JUNK_SIGNALS = [
    "enable javascript", "cookies to continue", "please enable js",
    "请启用javascript", "需要启用javascript", "verify you are human",
    "access denied", "403 forbidden", "checking your browser", "ddos protection",
]

# 永久垃圾域名
JUNK_DOMAINS = {
    "sncf-connect.com", "tgvtrains.com", "omio.cn", "omio.com",
    "raileurope.com", "thetrainline.com", "eurail.com",
}

# ── 工具 ──────────────────────────────

def run(cmd, timeout=30):
    try:
        r = subprocess.run(cmd, shell=True, capture_output=True, text=True, timeout=timeout)
        return r.stdout.strip(), r.returncode
    except subprocess.TimeoutExpired:
        return "", 124

def now_ts():
    return datetime.now(timezone(timedelta(hours=8))).strftime("%Y%m%d_%H%M%S")

# ═══════════════════════════════════════
# 阶段一：搜索计划
# ═══════════════════════════════════════
def build_search_plan(query: str) -> list[dict]:
    """生成 6 轮中文搜索计划（供 SearXNG 使用）。"""
    en_kw = _to_english(query) if _has_cjk(query) else query
    print(f"[计划] 中文搜索关键词: {query}")

    tokens = _tokenize_query(query)

    angles = [
        ("定义与概述", f"{query} 是什么 定义"),
        ("原理与技术", f"{query} 技术 原理 方法"),
        ("应用与场景", f"{query} 应用 场景 案例"),
        ("产业链与厂商", f"{query} 产业链 厂商 企业"),
        ("进展与动态", f"{query} 进展 最新 2025"),
        ("竞争与挑战", f"{query} 竞争 对比 挑战"),
    ]

    plan = []
    for i, (angle, seed) in enumerate(angles):
        plan.append({
            "round": i + 1, "angle": angle, "query": seed,
            "tokens": list(tokens), "status": "pending",
        })
    return plan


def build_search_plan_en(query: str) -> list[dict]:
    """生成 6 轮英文搜索计划（供 Firecrawl 使用）。"""
    en_kw = _to_english(query) if _has_cjk(query) else query
    print(f"[计划] 英文搜索关键词: {en_kw}")

    tokens = _tokenize_query(en_kw)

    angles = [
        ("定义与概述", f"{en_kw} definition overview what is"),
        ("原理与技术", f"{en_kw} technology principles mechanism"),
        ("应用与场景", f"{en_kw} applications use cases industry"),
        ("产业链与厂商", f"{en_kw} supply chain manufacturers companies"),
        ("进展与动态", f"{en_kw} latest developments progress 2025 2026"),
        ("竞争与挑战", f"{en_kw} competition comparison challenges alternatives"),
    ]

    plan = []
    for i, (angle, seed) in enumerate(angles):
        plan.append({
            "round": i + 1, "angle": angle, "query": seed,
            "tokens": list(tokens), "status": "pending",
        })
    return plan


def _has_cjk(text: str) -> bool:
    return bool(re.search(r'[\u4e00-\u9fff\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af]', text))


# 翻译缓存（会话内）
_TRANSLATION_CACHE: dict[str, str] = {}


def _to_english(text: str) -> str:
    """中文→英文。subprocess 隔离，5s 超时。纯英文直接返回。"""
    has_cjk = bool(re.search(r'[\u4e00-\u9fff\u3040-\u309f\u30a0-\u30ff\uac00-\ud7af]', text))
    if not has_cjk:
        return text.strip()
    if text in _TRANSLATION_CACHE:
        return _TRANSLATION_CACHE[text]
    # subprocess 隔离翻译调用，防止卡死主进程
    code = f"""
from translate import Translator
print(Translator(to_lang='en', from_lang='zh').translate({text!r}))
"""
    out, code = run(f"python3 -c {_shell_quote(code)}", timeout=10)
    if code == 0 and out and len(out) > 1 and out != text:
        _TRANSLATION_CACHE[text] = out.strip()
        return out.strip()
    print(f"[翻译] 失败（code={code}），使用原词")
    return text.strip()


def _shell_quote(s: str) -> str:
    """简陋 shell quote，避免 shlex 依赖。"""
    return "'" + s.replace("'", "'\\''") + "'"


def _tokenize_query(query: str) -> set[str]:
    """中文友好分词：按分隔 + 2-gram。"""
    tokens = set()
    parts = re.split(r'[\s,，、。；;：:！!？?()（）【】\[\]《》""''/\\|@#$%^&*=+\-]+', query)
    for p in parts:
        p = p.strip().lower()
        if len(p) >= 2:
            tokens.add(p)
    clean = re.sub(r'[\s,，、。；;：:！!？?()（）【】\[\]《》""''/\\|@#$%^&*=+\-]+', '', query)
    for i in range(len(clean) - 1):
        bg = clean[i:i+2]
        if not bg[0].isspace():
            tokens.add(bg.lower())
    return tokens


# ═══════════════════════════════════════
# 阶段二：搜索后端
# ═══════════════════════════════════════

def search_ddgs(query: str) -> tuple[list[dict], bool]:
    """ddgs Python API。"""
    try:
        from ddgs import DDGS
        ddgs = DDGS()
        with ThreadPoolExecutor(max_workers=1) as pool:
            future = pool.submit(lambda: list(ddgs.text(query, max_results=MAX_RESULTS_PER_ROUND)))
            try:
                raw = future.result(timeout=DDGS_TIMEOUT)
            except FuturesTimeout:
                return [], True
        results = []
        for r in raw:
            results.append({
                "title": r.get("title", ""),
                "href": r.get("href", ""),
                "body": r.get("body", ""),
                "source": "ddgs",
            })
        return results, False
    except Exception:
        return [], True


def search_searxng(query: str) -> tuple[list[dict], bool]:
    """SearXNG 国内引擎搜索。"""
    import urllib.request, urllib.parse
    params = urllib.parse.urlencode({
        "q": query, "format": "json",
        "engines": SEARXNG_ENGINES, "language": "zh-CN",
    })
    url = f"{SEARXNG_URL}/search?{params}"
    try:
        req = urllib.request.Request(url, headers={"User-Agent": "deep-search/3.2"})
        with urllib.request.urlopen(req, timeout=25) as resp:
            data = json.loads(resp.read())
        results = []
        for r in data.get("results", []):
            results.append({
                "title": r.get("title", ""),
                "href": r.get("url", ""),
                "body": r.get("content", ""),
                "source": f"searxng:{','.join(r.get('engines', []))}",
            })
        return results, False
    except Exception:
        return [], True


def search_firecrawl(query: str) -> tuple[list[dict], bool]:
    """Firecrawl keyless 搜索。失败重试 1 次（限频应对）。"""
    try:
        from firecrawl.v2.client import FirecrawlClient  # pyright: ignore[reportMissingImports]
    except ImportError:
        return [], True
    
    for attempt in range(2):
        try:
            client = FirecrawlClient()
            data = client.search(query)
            results = []
            for item in data.web[:MAX_RESULTS_PER_ROUND]:
                results.append({
                    "title": item.title or "",
                    "href": item.url or "",
                    "body": item.description or "",
                    "source": "firecrawl",
                })
            return results, False
        except Exception:
            if attempt == 0:
                time.sleep(3)
    return [], True


import threading

# ═══════════════════════════════════════
# 阶段三：多轮搜索（通用）
# ═══════════════════════════════════════

def multi_round_search(
    plan: list[dict],
    searcher,
    searcher_name: str,
    out_dir: Path,
    seen_urls: set = None,
    url_lock: threading.Lock = None,
) -> list[dict]:
    """执行多轮搜索，返回去重结果列表。
    传入 seen_urls + url_lock 可实现线程安全的跨引擎去重。
    """
    if seen_urls is None:
        seen_urls = set()
    all_results = []

    for step in plan:
        if step["status"] == "skipped":
            continue

        query = step["query"]
        print(f"  [{searcher_name}] Round {step['round']}/{MAX_ROUNDS}: \"{query}\"")

        results, failed = searcher(query)

        if failed:
            print(f"    ✗ 搜索失败")
            step["status"] = "failed"
            continue

        new_results = []
        for r in results:
            href = r.get("href", "")
            if href:
                if url_lock:
                    with url_lock:
                        if href in seen_urls:
                            continue
                        seen_urls.add(href)
                else:
                    if href in seen_urls:
                        continue
                    seen_urls.add(href)
                r["_round"] = step["round"]
                r["_angle"] = step["angle"]
                new_results.append(r)

        step["status"] = "done"
        step["found"] = len(new_results)
        all_results.extend(new_results)
        print(f"    ✓ {len(new_results)} 条新结果（跨引擎累计 {len(seen_urls)}）")

        if step["round"] < MAX_ROUNDS:
            time.sleep(2)  # 冷却：SearXNG/Firecrawl API 自有限频，只需短间隔

    return all_results


# ═══════════════════════════════════════
# 阶段四：相关性过滤
# ═══════════════════════════════════════

def filter_results(results: list[dict], original_query: str) -> tuple[list[dict], list[dict]]:
    """基于原始查询词过滤噪音。只看标题，宽松匹配。"""
    query_tokens = _tokenize_query(original_query)

    clean, removed = [], []
    for r in results:
        href = r.get("href", "")
        try:
            domain = urlparse(href).netloc.lower()
        except Exception:
            domain = ""

        if any(jd in domain for jd in JUNK_DOMAINS):
            removed.append({**r, "_reason": f"junk_domain:{domain}"})
            continue

        # 只看标题，宽松评分（任一 token 命中即保留）
        title = r.get("title", "")
        text_tokens = _tokenize_query(title)
        if query_tokens:
            hits = sum(1 for t in query_tokens if t in text_tokens)
            # 命中 ≥1 个中文 2-gram 即保留
            if hits == 0:
                removed.append({**r, "_reason": "no_token_match"})
                continue

        clean.append(r)

    return clean, removed


# ═══════════════════════════════════════
# 阶段五：抓取（scrapling 优先 → Firecrawl 兜底）
# ═══════════════════════════════════════

def _firecrawl_scrape(url: str, out_md: Path) -> dict:
    """Firecrawl keyless 抓取单 URL。失败返回 None 标记。"""
    try:
        from firecrawl.v2.client import FirecrawlClient  # pyright: ignore[reportMissingImports]
        client = FirecrawlClient()
        result = client.scrape(url)
        md = result.markdown if hasattr(result, 'markdown') else ""
        if md and len(md) > 100:
            # 跳过导航垃圾
            lines = []
            for line in md.split("\n"):
                s = line.strip()
                if len(s) < 20: continue
                if s.startswith(("<", "{", "/*", "//")): continue
                lines.append(s)
            clean = "\n".join(lines)[:8000]
            out_md.write_text(clean, encoding="utf-8", errors="replace")
            return {"url": url, "file": str(out_md), "method": "firecrawl_scrape", "text": clean}
    except Exception as e:
        pass
    return {"url": url, "file": None, "method": "firecrawl_failed", "text": "", "error": "firecrawl_exhausted"}


def extract_url(url: str, out_dir: Path, idx: int) -> dict:
    """scrapling 两层抓取。失败返回标记。"""
    domain = urlparse(url).netloc.lower()
    fname = re.sub(r'[^\w\-]', '_', url.rsplit("/", 1)[-1][:40] or "index")
    out_md = out_dir / f"{idx:02d}_{domain}_{fname}.md"

    if domain in {"mp.weixin.qq.com", "tieba.baidu.com"}:
        return {"url": url, "file": None, "method": "skipped", "text": "", "error": "blocked_domain"}

    def _try(cmd, timeout):
        _, code = run(cmd, timeout=timeout)
        if code == 0 and out_md.exists() and out_md.stat().st_size > 100:
            raw = out_md.read_text(encoding="utf-8", errors="replace")
            if not any(s in raw[:500].lower() for s in JUNK_SIGNALS):
                lines = []
                for line in raw.split("\n"):
                    s = line.strip()
                    if len(s) < 20: continue
                    if s.startswith(("<", "{", "/*", "//")): continue
                    lines.append(s)
                return True, "\n".join(lines)[:8000]
        return False, ""

    # Layer 1: HTTP
    ok, text = _try(f"scrapling extract get '{url}' {out_md}", FETCH_TIMEOUT)
    if ok:
        return {"url": url, "file": str(out_md), "method": "scrapling_get", "text": text}

    # Layer 2: JS
    ok, text = _try(f"scrapling extract fetch '{url}' {out_md} --disable-resources --network-idle", FETCH_TIMEOUT + 10)
    if ok:
        return {"url": url, "file": str(out_md), "method": "scrapling_fetch", "text": text}

    return {"url": url, "file": None, "method": "scrapling_failed", "text": "", "error": "scrapling_exhausted"}


def scrape_with_fallback(results: list[dict], fulltext_dir: Path) -> tuple[list[dict], list[dict], list[dict]]:
    """scrapling 优先抓取全部，失败项由 Firecrawl 兜底。
    返回 (成功列表, 仍失败列表, Firecrawl兜底列表)。
    """
    # Phase 1: scrapling 并发
    scraped = [None] * len(results)
    with ThreadPoolExecutor(max_workers=SCRAPING_WORKERS) as pool:
        futures = {}
        for i, r in enumerate(results):
            f = pool.submit(extract_url, r["href"], fulltext_dir, i + 1)
            futures[f] = i

        for f in as_completed(futures):
            i = futures[f]
            try:
                out = f.result()
                out["title"] = results[i].get("title", "")
                scraped[i] = out
            except Exception as e:
                scraped[i] = {
                    "url": results[i].get("href", ""), "title": results[i].get("title", ""),
                    "file": None, "method": "failed", "text": "", "error": str(e)
                }

    for i in range(len(scraped)):
        if scraped[i] is None:
            scraped[i] = {
                "url": results[i].get("href", ""), "title": results[i].get("title", ""),
                "file": None, "method": "failed", "text": "", "error": "no_attempt"
            }

    # 分类
    success = [s for s in scraped if s["method"] not in ("failed", "skipped", "scrapling_failed")]
    scrapling_failed = [s for s in scraped if s["method"] in ("scrapling_failed",)]

    # Phase 2: Firecrawl 兜底
    firecrawl_saved = []
    still_failed = []
    if scrapling_failed:
        print(f"\n[兜底] Firecrawl 抓取 {len(scrapling_failed)} 条 scrapling 失败项...")
        for i, item in enumerate(scrapling_failed):
            url = item["url"]
            fname = re.sub(r'[^\w\-]', '_', url.rsplit("/", 1)[-1][:40] or "index")
            out_md = fulltext_dir / f"fc_{i+1:02d}_{fname}.md"
            fc_out = _firecrawl_scrape(url, out_md)
            fc_out["title"] = item.get("title", "")
            if fc_out.get("text"):
                success.append(fc_out)
                firecrawl_saved.append(fc_out)
                print(f"  ✓ {urlparse(url).netloc}")
            else:
                still_failed.append({**item, "error": "both_exhausted"})
                print(f"  ✗ {urlparse(url).netloc}")

    # 补回已跳过的
    still_failed += [s for s in scraped if s["method"] == "skipped"]

    return success, still_failed, firecrawl_saved


# ═══════════════════════════════════════
# 阶段六：报告
# ═══════════════════════════════════════

def build_report(success: list[dict], failed: list[dict], query: str,
                 plan: list[dict], firecrawl_saved: list[dict] = None) -> str:
    ts = now_ts()
    fc_count = len(firecrawl_saved) if firecrawl_saved else 0
    lines = [
        f"# 🔬 {query} 深度搜索",
        f"*{ts} · 成功 {len(success)} 条 · 失败 {len(failed)} 条"
        + (f" · Firecrawl兜底 {fc_count} 条" if fc_count else "") + "*",
        "",
        "## 搜索计划",
    ]
    for step in plan:
        icon = {"done": "✅", "failed": "❌", "skipped": "⏭️", "pending": "⬜"}.get(step["status"], "❓")
        lines.append(f"- {icon} Round {step['round']}: {step['angle']} — \"{step['query']}\"")

    lines.extend(["", "## 抓取结果", ""])
    for i, r in enumerate(success, 1):
        title = r.get("title", "(无标题)")
        url = r.get("url", "")
        domain = urlparse(url).netloc
        method = r.get("method", "?")
        text = r.get("text", "")[:500]
        lines.append(f"### {i}. {title}")
        lines.append(f"  来源：{domain}  `{method}`")
        lines.append(f"  {text}")
        lines.append(f"  原文：{url}")
        lines.append("")

    if failed:
        lines.extend(["## ⚠️ 抓取失败清单", ""])
        lines.append("| # | 标题 | URL | 原因 |")
        lines.append("|---|------|-----|------|")
        for i, f in enumerate(failed, 1):
            title = f.get("title", "?")[:40]
            url = f.get("url", "")
            err = f.get("error", f.get("method", "?"))
            lines.append(f"| {i} | {title} | {url} | {err} |")
        lines.extend(["", f"> 共 {len(failed)} 条未能抓取。是否启用 browser-act 补充抓取？"])

    if fc_count:
        lines.extend(["", "## 🔥 Firecrawl 兜底详情", ""])
        for i, r in enumerate(firecrawl_saved, 1):
            lines.append(f"- {r.get('title', '?')[:60]} ← `{r.get('url', '')}`")

    return "\n".join(lines)


# ═══════════════════════════════════════
# 主流程
# ═══════════════════════════════════════

def main(query: str) -> str:
    out_dir = OUTPUT_ROOT / now_ts()
    out_dir.mkdir(parents=True, exist_ok=True)
    fulltext_dir = out_dir / "fulltext"
    fulltext_dir.mkdir(exist_ok=True)

    print(f"[deep-search v3.2] 查询: {query}")
    print(f"[deep-search v3.2] 输出: {out_dir}")

    # ── 阶段一：搜索计划 ──
    plan = build_search_plan(query)
    print(f"[计划] 生成 {len(plan)} 轮搜索计划")
    for step in plan:
        print(f"  Round {step['round']}: [{step['angle']}] \"{step['query']}\"")

    # ── 阶段二：ddgs 首轮探测 ──
    print(f"\n[阶段二] ddgs 首轮探测...")
    probe_plan = [plan[0]]
    probe_results = multi_round_search(probe_plan, search_ddgs, "ddgs(probe)", out_dir)
    ddgs_ok = bool(probe_results)

    if ddgs_ok:
        print(f"[ddgs] 首轮成功（{len(probe_results)} 条），继续剩余 {MAX_ROUNDS - 1} 轮...")
        remaining_plan = [s for s in plan if s["round"] > 1]
        for s in remaining_plan:
            s["status"] = "pending"
        more = multi_round_search(remaining_plan, search_ddgs, "ddgs", out_dir)
        results = probe_results + more
    else:
        print("[ddgs] 首轮失败，重试 1 次...")
        time.sleep(3)
        probe_plan[0]["status"] = "pending"
        probe_results = multi_round_search(probe_plan, search_ddgs, "ddgs(retry)", out_dir)

        if probe_results:
            print(f"[ddgs] 重试成功（{len(probe_results)} 条），继续剩余 {MAX_ROUNDS - 1} 轮...")
            remaining_plan = [s for s in plan if s["round"] > 1]
            for s in remaining_plan:
                s["status"] = "pending"
            more = multi_round_search(remaining_plan, search_ddgs, "ddgs", out_dir)
            results = probe_results + more
        else:
            # ── 阶段三：ddgs 不可用 → SearXNG + Firecrawl 双引擎 ──
            print(f"\n[阶段三] ddgs 不可用，启动双引擎搜索...")
            print(f"  SearXNG: 国内引擎 {SEARXNG_ENGINES}")
            print(f"  Firecrawl: keyless 免费层")

            # SearXNG + Firecrawl 并行搜索
            print("\n[SearXNG + Firecrawl] 双引擎并行 6 轮搜索...")
            seen_urls = set()
            url_lock = threading.Lock()
            sx_results = []
            fc_results = []

            def _run_sx():
                nonlocal sx_results
                plan_sx = build_search_plan(query)
                sx_results = multi_round_search(plan_sx, search_searxng, "SearXNG", out_dir, seen_urls, url_lock)

            def _run_fc():
                nonlocal fc_results
                plan_fc = build_search_plan_en(query)
                fc_results = multi_round_search(plan_fc, search_firecrawl, "Firecrawl", out_dir, seen_urls, url_lock)

            with ThreadPoolExecutor(max_workers=2) as pool:
                f1 = pool.submit(_run_sx)
                f2 = pool.submit(_run_fc)
                f1.result()
                f2.result()

            results = sx_results + fc_results
            # 标记原始 plan 的状态
            for step in plan:
                step["status"] = "done" if results else "failed"

    if not results:
        print("[deep-search] 所有搜索引擎均无结果。")
        return ""

    # ── 阶段四：过滤 ──
    clean, removed = filter_results(results, query)
    print(f"\n[过滤] {len(clean)} 条保留，{len(removed)} 条移除")
    for r in removed[:3]:
        print(f"  - {r.get('title','')[:50]} → {r.get('_reason','')}")

    # 保存
    (out_dir / "results.json").write_text(
        json.dumps(clean, ensure_ascii=False, indent=2), encoding="utf-8")

    # ── 阶段五：scrapling 优先 → Firecrawl 兜底 ──
    if len(clean) > MAX_SCRAPE:
        print(f"\n[抓取] 限制 {MAX_SCRAPE}/{len(clean)} 条（超出截断）")
        clean = clean[:MAX_SCRAPE]
    print(f"\n[抓取] scrapling 抓取 {len(clean)} 条...")
    success, failed, firecrawl_saved = scrape_with_fallback(clean, fulltext_dir)
    print(f"[抓取] 成功 {len(success)}，失败 {len(failed)}，Firecrawl兜底 {len(firecrawl_saved)}")

    # ── 阶段六：报告 ──
    report = build_report(success, failed, query, plan, firecrawl_saved)
    report_path = out_dir / "final_report.md"
    report_path.write_text(report, encoding="utf-8")

    print(f"\n[完成] 报告: {report_path}")
    print(f"[失败清单] {len(failed)} 条待抓取")

    print("\n" + "=" * 60)
    print(report)

    return str(report_path)


if __name__ == "__main__":
    if len(sys.argv) < 2:
        print("用法: python3 deep_search.py <搜索关键词>")
        sys.exit(1)
    query = " ".join(sys.argv[1:])
    main(query)
