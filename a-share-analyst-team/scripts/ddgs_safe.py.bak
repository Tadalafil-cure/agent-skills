#!/usr/bin/env python3
"""
ddgs 安全搜索封装 —— 文件锁限频，多 Agent 并发安全

用法:
    python3 ddgs_safe.py -q "搜索词" -m 6
    python3 ddgs_safe.py -q "搜索词" -m 6 --json  # JSON 输出

限频规则:
    - 同一 TASK_BASE 下所有搜索 ≥20s 间隔
    - 共享锁文件: {TASK_BASE}/data/.ddgs_lock
    - 自动等待、自动记录时间戳
"""

import argparse, json, os, sys, time, subprocess
from pathlib import Path
from datetime import datetime

MIN_INTERVAL = 20  # 最小搜索间隔（秒）
LOCK_FILE = None
SEARCH_TIMEOUT = 45  # ddgs 超时


def get_lock_path():
    """从环境或默认路径获取锁文件位置"""
    task_base = os.environ.get("TASK_BASE", "/tmp")
    return Path(task_base) / "data" / ".ddgs_lock"


def wait_if_needed(lock_path, min_interval=MIN_INTERVAL):
    """检查上次搜索时间，必要时等待"""
    lock_path = Path(lock_path)
    lock_path.parent.mkdir(parents=True, exist_ok=True)

    if lock_path.exists():
        try:
            last_ts = float(lock_path.read_text().strip())
            elapsed = time.time() - last_ts
            if elapsed < min_interval:
                wait = min_interval - elapsed
                print(f"[ddgs_safe] 距上次搜索 {elapsed:.1f}s，等待 {wait:.1f}s...",
                      file=sys.stderr)
                time.sleep(wait)
        except (ValueError, OSError):
            pass


def update_lock(lock_path):
    """更新搜索时间戳"""
    lock_path.parent.mkdir(parents=True, exist_ok=True)
    lock_path.write_text(str(time.time()))


def search(query, max_results=10, json_output=False):
    """执行 ddgs 搜索，带限频保护（v0.8.7：CLI→Python API）"""
    lock_path = get_lock_path()
    wait_if_needed(lock_path)

    try:
        from ddgs import DDGS
        ddgs = DDGS()
        raw = list(ddgs.text(query, max_results=max_results))
        update_lock(lock_path)

        results = []
        for r in raw:
            results.append({
                "title": r.get("title", ""),
                "href": r.get("href", ""),
                "body": r.get("body", ""),
            })

        if json_output:
            print(json.dumps(results, ensure_ascii=False, indent=2))
        else:
            for i, r in enumerate(results, 1):
                print(f"{i}.")
                print(f"title       {r['title']}")
                print(f"href        {r['href']}")
                print(f"body        {r['body']}")
                print()
        sys.exit(0)

    except ImportError:
        update_lock(lock_path)
        error_msg = {"error": "ddgs package not installed. pip install ddgs"}
        if json_output:
            print(json.dumps(error_msg, ensure_ascii=False))
        else:
            print("ERROR: ddgs package not installed", file=sys.stderr)
        sys.exit(1)

    except Exception as e:
        update_lock(lock_path)
        error_msg = {"error": str(e)}
        if json_output:
            print(json.dumps(error_msg, ensure_ascii=False))
        else:
            print(f"ERROR: {e}", file=sys.stderr)
        sys.exit(1)


def main():
    parser = argparse.ArgumentParser(description="ddgs 安全搜索（文件锁限频）")
    parser.add_argument("-q", "--query", required=True, help="搜索词")
    parser.add_argument("-m", "--max-results", type=int, default=10, help="最大结果数")
    parser.add_argument("--json", action="store_true", help="JSON 输出")
    args = parser.parse_args()

    search(args.query, args.max_results, args.json)


if __name__ == "__main__":
    main()
