{
  "type": "object",
  "properties": {
    "研报来源": {
      "type": "string",
      "description": "券商/机构名称，如'招商证券'、'中金公司'"
    },
    "覆盖日期": {
      "type": ["string", "null"],
      "description": "报告发布日期，如'2025-06-15'"
    },
    "分析师": {
      "type": ["string", "null"],
      "description": "署名分析师姓名"
    },
    "评级": {
      "type": ["string", "null"],
      "description": "投资评级：买入/增持/中性/减持/卖出"
    },
    "目标价": {
      "type": ["number", "null"],
      "description": "目标价（元）"
    },
    "核心假设": {
      "type": ["string", "null"],
      "description": "预测依赖的关键假设（如'白酒消费升级持续'、'直销占比提升至60%'）"
    },
    "风险提示": {
      "type": ["string", "null"],
      "description": "报告所列主要风险（如政策风险、竞争加剧、原材料涨价）"
    },
    "预测": {
      "type": "array",
      "description": "多年度预测列表。每项为一个财年的预测数字",
      "items": {
        "type": "object",
        "properties": {
          "预测年度": {
            "type": "string",
            "description": "预测对应的财年，如'2025E'、'2026E'、'2027E'"
          },
          "营收预测": {
            "type": ["number", "null"],
            "description": "预测营业收入（亿元）"
          },
          "净利预测": {
            "type": ["number", "null"],
            "description": "预测归母净利润（亿元）"
          },
          "EPS预测": {
            "type": ["number", "null"],
            "description": "预测每股收益（元）"
          },
          "营收增速": {
            "type": ["number", "null"],
            "description": "预测营业收入同比增长率(%)"
          },
          "净利增速": {
            "type": ["number", "null"],
            "description": "预测净利润同比增长率(%)"
          },
          "PE预测": {
            "type": ["number", "null"],
            "description": "基于目标价的预测市盈率"
          }
        }
      }
    }
  },
  "required": []
}
